<Page x:Class="UP1.Views.BookCatalogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="1100"
      Title="BookCatalogPage">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Панель поиска и фильтров -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBox x:Name="txtSearch" Width="300" Height="35" 
                     TextChanged="TxtSearch_TextChanged"
                     Background="#3C3C3C" Foreground="White" 
                     BorderBrush="#555555" Margin="0,0,15,0"
                     VerticalContentAlignment="Center"/>

            <ComboBox x:Name="cmbSort" Width="180" Height="35" SelectionChanged="CmbSort_SelectionChanged"
                      Background="#3C3C3C" Foreground="White" Margin="0,0,15,0">
                <ComboBoxItem Content="По названию (А-Я)" IsSelected="True"/>
                <ComboBoxItem Content="По названию (Я-А)"/>
                <ComboBoxItem Content="По оценке (высокая)"/>
                <ComboBoxItem Content="По оценке (низкая)"/>
            </ComboBox>

            <TextBlock Text="Жанры:" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <!-- Жанры добавим позже -->
        </StackPanel>

        <!-- Сетка книг -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <WrapPanel x:Name="booksPanel" ItemWidth="180" ItemHeight="280" 
                       Margin="10" HorizontalAlignment="Left"/>
        </ScrollViewer>
    </Grid>
</Page>