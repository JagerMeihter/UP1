<Window x:Class="UP1.Views.ReadBookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Чтение книги" 
        Height="650" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Background="#252526" Padding="15">
            <StackPanel Orientation="Horizontal">
                <Button Content="← Назад" Width="100" Height="35" Click="BtnBack_Click" 
                        Background="#3C3C3C" Foreground="White"/>

                <TextBlock x:Name="tbBookTitle" FontSize="20" FontWeight="Bold" 
                           Foreground="White" VerticalAlignment="Center" Margin="20,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Текст книги -->
        <ScrollViewer Grid.Row="1" Padding="40" VerticalScrollBarVisibility="Auto">
            <TextBlock x:Name="tbBookText" 
                       FontSize="16" 
                       Foreground="#E0E0E0"
                       TextWrapping="Wrap"
                       LineHeight="28"/>
        </ScrollViewer>
    </Grid>
</Window>