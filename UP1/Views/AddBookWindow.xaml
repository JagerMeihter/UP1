<Window x:Class="UP1.Views.AddBookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить новую книгу" 
        Height="550" Width="500"
        WindowStartupLocation="CenterScreen"
        Background="#2D2D2D">

    <Grid Margin="25">
        <StackPanel>
            <TextBlock Text="Новая книга" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Название книги" Foreground="#AAAAAA" Margin="0,0,0,5"/>
            <TextBox x:Name="txtTitle" Height="35" Margin="0,0,0,15"/>

            <TextBlock Text="Автор" Foreground="#AAAAAA" Margin="0,0,0,5"/>
            <TextBox x:Name="txtAuthor" Height="35" Margin="0,0,0,15" IsReadOnly="True"/>

            <TextBlock Text="Жанр" Foreground="#AAAAAA" Margin="0,0,0,5"/>
            <ComboBox x:Name="cmbGenre" Height="35" Margin="0,0,0,15">
                <ComboBoxItem>Фантастика</ComboBoxItem>
                <ComboBoxItem>Детектив</ComboBoxItem>
                <ComboBoxItem>Романтика</ComboBoxItem>
                <ComboBoxItem>Поэзия</ComboBoxItem>
                <ComboBoxItem>Ужасы</ComboBoxItem>
            </ComboBox>

            <TextBlock Text="Описание" Foreground="#AAAAAA" Margin="0,0,0,5"/>
            <TextBox x:Name="txtDescription" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,15"/>

            <TextBlock Text="Текст книги (начало)" Foreground="#AAAAAA" Margin="0,0,0,5"/>
            <TextBox x:Name="txtText" Height="120" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,20"/>

            <Button Content="Опубликовать книгу" Height="50" FontSize="16" 
                    Background="#4CAF50" Foreground="White" Click="BtnPublish_Click"/>
        </StackPanel>
    </Grid>
</Window>