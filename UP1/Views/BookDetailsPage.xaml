<Page x:Class="UP1.Views.BookDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="650" 
      d:DesignWidth="1100"
      Title="BookDetailsPage">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая часть - обложка и информация -->
        <StackPanel Grid.Column="0" Margin="0,0,30,0">
            <Border Width="250" Height="350" Background="#3C3C3C" CornerRadius="10" HorizontalAlignment="Center">
                <TextBlock x:Name="tbCover" FontSize="120" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <TextBlock x:Name="tbTitle" FontSize="22" FontWeight="Bold" Foreground="White" 
                       TextWrapping="Wrap" Margin="0,20,0,5" TextAlignment="Center"/>

            <TextBlock x:Name="tbAuthor" FontSize="16" Foreground="#AAAAAA" 
                       TextAlignment="Center" Margin="0,0,0,15"/>

            <TextBlock x:Name="tbRating" FontSize="18" Foreground="Gold" 
                       TextAlignment="Center" Margin="0,0,0,20"/>

            <Button Content="📖 Читать книгу" Height="50" FontSize="16" 
                    Background="#4CAF50" Foreground="White" Margin="0,10"
                    Click="BtnRead_Click"/>

            <Button Content="⭐ Оставить отзыв" Height="45" Margin="0,8"
                    Background="#2196F3" Foreground="White" Click="BtnReview_Click"/>

            <Button Content="🚩 Пожаловаться на книгу" Height="45" Margin="0,8"
                    Background="#F44336" Foreground="White" Click="BtnReportBook_Click"/>
        </StackPanel>

        <!-- Правая часть - описание и отзывы -->
        <StackPanel Grid.Column="1">
            <TextBlock Text="Описание" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
            <TextBlock x:Name="tbDescription" TextWrapping="Wrap" Foreground="#DDDDDD" 
                       FontSize="14" Margin="0,0,0,30" Height="120"/>

            <!-- Отзывы -->
            <TextBlock Text="Отзывы" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
            <ScrollViewer Height="350" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="reviewsPanel"/>
            </ScrollViewer>
        </StackPanel>
    </Grid>
</Page>