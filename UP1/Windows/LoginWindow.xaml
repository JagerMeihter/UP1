<Window x:Class="UP1.Windows.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Читай, Пиши и не спиши" 
        Height="450" Width="380"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#2D2D2D">

    <Grid Margin="30">
        <StackPanel VerticalAlignment="Center">

            <TextBlock Text="Читай, Пиши и не спиши" 
                       FontSize="22" FontWeight="Bold" Foreground="White"
                       HorizontalAlignment="Center" Margin="0,0,0,40"/>

            <TextBlock Text="Логин или Email" Foreground="#AAAAAA" Margin="0,0,0,5"/>
            <TextBox x:Name="txtLogin" Height="35" FontSize="14" Margin="0,0,0,15" Background="#3C3C3C" Foreground="White" BorderBrush="#555555"/>

            <TextBlock Text="Пароль" Foreground="#AAAAAA" Margin="0,0,0,5"/>
            <PasswordBox x:Name="txtPassword" Height="35" FontSize="14" Margin="0,0,0,20" Background="#3C3C3C" Foreground="White" BorderBrush="#555555"/>

            <Button Content="Войти" 
                    Click="BtnLogin_Click"
                    Height="45" FontSize="16" Margin="0,10" Background="#4CAF50" Foreground="White"/>

            <Button Content="Регистрация" 
                    Click="BtnRegister_Click"
                    Height="45" FontSize="16" Margin="0,5" Background="Transparent" Foreground="#2196F3" BorderBrush="#2196F3"/>
        </StackPanel>
    </Grid>
</Window>