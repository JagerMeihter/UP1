<Window x:Class="UP1.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Читай, Пиши и не спиши" 
        Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        WindowStyle="None"
        AllowsTransparency="False">

    <Grid>
        <!-- Sidebar -->
        <Grid Width="70" HorizontalAlignment="Left" Background="#252526">
            <StackPanel Margin="0,20,0,0">
                <!-- Логотип -->
                <TextBlock Text="📖" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <!-- Кнопки меню -->
                <Button x:Name="btnCatalog" Height="60" Click="BtnCatalog_Click" ToolTip="Каталог книг">
                    <TextBlock Text="📚" FontSize="24"/>
                </Button>

                <Button x:Name="btnLists" Height="60" Click="BtnLists_Click" ToolTip="Мои списки">
                    <TextBlock Text="📋" FontSize="24"/>
                </Button>

                <Button x:Name="btnAuthor" Height="60" Click="BtnAuthor_Click" ToolTip="Страница автора" Visibility="Collapsed">
                    <TextBlock Text="✍️" FontSize="24"/>
                </Button>

                <Button x:Name="btnAdmin" Height="60" Click="BtnAdmin_Click" ToolTip="Администрирование" Visibility="Collapsed">
                    <TextBlock Text="⚙️" FontSize="24"/>
                </Button>
                <!-- Предупреждение о заморозке -->
                <Button x:Name="btnFreezeWarning" Height="60" Click="BtnFreezeWarning_Click" 
                     ToolTip="Аккаунт заморожен!" Background="#D32F2F" Visibility="Collapsed">
                    <TextBlock Text="⚠️" FontSize="28"/>
                </Button>

                <Button x:Name="btnProfile" Height="60" Click="BtnProfile_Click" ToolTip="Профиль" Margin="0,20,0,0">
                    <TextBlock Text="👤" FontSize="24"/>
                </Button>
            </StackPanel>

            <!-- Кнопка выхода внизу -->
            <Button Content="⏻" 
                    Click="BtnLogout_Click"
                    Width="50" Height="50"
                    HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,20"
                    Background="#E53935" Foreground="White" FontSize="20"/>
        </Grid>

        <!-- Основная область контента -->
        <Grid x:Name="MainContent" Margin="70,0,0,0" Background="#2D2D2D">
            <TextBlock x:Name="tbPageTitle" 
                       Text="Каталог книг" 
                       FontSize="28" FontWeight="Bold" Foreground="White"
                       HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,20"/>

            <!-- Сюда будем загружать страницы -->
            <Frame x:Name="ContentFrame" NavigationUIVisibility="Hidden" Margin="0,70,0,0"/>
        </Grid>
    </Grid>
</Window>